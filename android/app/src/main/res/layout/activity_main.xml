<?xml version="1.0" encoding="utf-8"?>
<LinearLayout 
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="24dp"
    android:background="@color/black">

    <!-- 标题 -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="语音助手"
        android:textSize="28sp"
        android:textColor="@color/white"
        android:layout_gravity="center_horizontal"
        android:layout_marginBottom="32dp"/>

    <!-- 服务器设置 -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginBottom="16dp">

        <EditText
            android:id="@+id/etServerIp"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="2"
            android:hint="@string/hint_server_ip"
            android:text="192.168.1.100"
            android:inputType="text"
            android:textColor="@color/white"
            android:textColorHint="#80FFFFFF"
            android:backgroundTint="@color/purple_500"
            android:padding="12dp">
            <requestFocus />
        </EditText>

        <EditText
            android:id="@+id/etServerPort"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginStart="8dp"
            android:hint="@string/hint_port"
            android:text="8765"
            android:inputType="number"
            android:textColor="@color/white"
            android:textColorHint="#80FFFFFF"
            android:backgroundTint="@color/purple_500"
            android:padding="12dp"/>
    </LinearLayout>

    <!-- 状态指示 -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:layout_marginBottom="24dp">

        <View
            android:id="@+id/statusIndicator"
            android:layout_width="16dp"
            android:layout_height="16dp"
            android:background="@drawable/status_disconnected"
            android:layout_marginEnd="12dp"/>

        <TextView
            android:id="@+id/tvStatus"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/text_status_disconnected"
            android:textSize="16sp"
            android:textColor="@color/white"/>
    </LinearLayout>

    <!-- 控制按钮 -->
    <Button
        android:id="@+id/btnConnect"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="@string/text_connect"
        android:backgroundTint="@color/purple_500"
        android:textColor="@color/white"
        android:padding="16dp"
        android:textSize="16sp"
        android:layout_marginBottom="12dp"/>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal">

        <Button
            android:id="@+id/btnSettings"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="@string/text_settings"
            android:backgroundTint="@color/teal_700"
            android:textColor="@color/white"
            android:layout_marginEnd="8dp"/>

        <Button
            android:id="@+id/btnTest"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="@string/text_test"
            android:backgroundTint="@color/teal_700"
            android:textColor="@color/white"
            android:layout_marginStart="8dp"/>
    </LinearLayout>

    <!-- 识别结果展示区 -->
    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="#30FFFFFF"
        android:layout_marginVertical="24dp"/>

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="识别内容"
        android:textSize="14sp"
        android:textColor="#80FFFFFF"
        android:layout_marginBottom="8dp"/>

    <TextView
        android:id="@+id/tvRecognized"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="@string/text_waiting_input"
        android:textSize="18sp"
        android:textColor="@color/teal_200"
        android:minHeight="48dp"
        android:gravity="center_vertical"
        android:layout_marginBottom="16dp"/>

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="执行结果"
        android:textSize="14sp"
        android:textColor="#80FFFFFF"
        android:layout_marginBottom="8dp"/>

    <TextView
        android:id="@+id/tvResponse"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="@string/text_waiting_result"
        android:textSize="16sp"
        android:textColor="@color/white"
        android:minHeight="48dp"
        android:gravity="center_vertical"/>

</LinearLayout>